@prefix ex: <http://example.org/>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix odrl: <http://www.w3.org/ns/odrl/2/>.
@prefix dpv: <https://w3id.org/dpv#> .
@prefix dpv-odrl: <https://w3id.org/dpv/mappings/odrl#> .

ex:policy-processing a odrl:Policy ;
    odrl:uid ex:policy-processing ;
    odrl:profile dpv-odrl: ;
    odrl:permission [
        odrl:assigner ex:DataController ;
        odrl:target ex:asset ;
        odrl:action dpv-odrl:Anonymise ] .

ex:DataController a dpv-odrl:DataController .