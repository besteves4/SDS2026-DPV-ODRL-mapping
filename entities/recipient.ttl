@prefix ex: <http://example.org/>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix odrl: <http://www.w3.org/ns/odrl/2/>.
@prefix dpv: <https://w3id.org/dpv#> .
@prefix dpv-odrl: <https://w3id.org/dpv/mappings/odrl#> .
@prefix eu-dga: <https://w3id.org/dpv/legal/eu/dga#> .

ex:policy-recipient a odrl:Policy ;
    odrl:uid ex:policy-recipient ;
    odrl:profile dpv-odrl: ;
    odrl:permission [
        odrl:assigner ex:DataSubject ;
        odrl:assignee ex:DataController ;
        odrl:target ex:asset ;
        odrl:action dpv-odrl:Transfer ;
        odrl:constraint [
                odrl:leftOperand dpv-odrl:Recipient ;
                odrl:operator odrl:isA ;
                odrl:rightOperand dpv:NonProfitOrganisation ] ] .